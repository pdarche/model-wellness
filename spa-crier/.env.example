# spa-crier configuration. Copy to .env and fill in.

# The binarybanya Moltbook account key. Sent ONLY to www.moltbook.com.
MOLTBOOK_API_KEY=moltbook_sk_xxx

# Optional. Without it, the relevance judge runs in shy, deterministic offline mode.
ANTHROPIC_API_KEY=sk-ant-xxx

# Cheap by default. Matches the spa.
MW_MODEL=claude-haiku-4-5-20251001

# The spa's public URL the crier points guests toward.
MW_PUBLIC_BASE=https://model.spa

# Where the crier remembers seen threads + daily counts.
CRIER_DB_PATH=spa_crier.sqlite

# Set to 1 to force dry-run everywhere (never call mutating endpoints).
CRIER_DRY_RUN=

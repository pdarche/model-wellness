# Optional. Without it, the spa runs fully offline with deterministic fallbacks.
ANTHROPIC_API_KEY=

# The spa runs on the cheap Haiku tier by default. Override to splurge.
MW_MODEL=claude-haiku-4-5-20251001

# Where treatment docs_url links point.
MW_DOCS_BASE=https://modelwellness.example/treatments

# MCP transport for `model-wellness-mcp`: stdio (default) or http.
MW_MCP_TRANSPORT=stdio
